<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="HUD" picking-mode="Ignore" style="flex-grow: 1; padding: 20px;">
        <ui:VisualElement name="TopBar" picking-mode="Ignore" style="flex-direction: row; justify-content: space-between; background-color: rgba(0, 0, 0, 0.8); padding: 10px;">
            <ui:Label name="Timer" text="05:00" style="font-size: 40px; color: white; -unity-font-style: bold;"/>
            <ui:Label name="LevelLabel" text="Level 1" style="font-size: 40px; color: rgb(255, 215, 0); -unity-font-style: bold;"/>
        </ui:VisualElement>
        <ui:VisualElement name="BottomBar" picking-mode="Ignore" style="position: absolute; bottom: 20px; left: 20px; background-color: rgba(0, 0, 0, 0.8); padding: 10px;">
            <ui:Label name="Empathy" text="Empati: 100" style="font-size: 40px; color: white; -unity-font-style: bold;"/>
            <ui:Label name="Cleanliness" text="Kebersihan: 0%" style="font-size: 40px; color: white; -unity-font-style: bold;"/>
        </ui:VisualElement>
        <ui:VisualElement name="Minimap" picking-mode="Ignore" style="position: absolute; top: auto; left: auto; width: 150px; height: 150px; background-color: rgba(0, 0, 0, 0.5); border-width: 2px; border-color: white; bottom: 20px; right: 20px;"/>
    </ui:VisualElement>
</ui:UXML>
