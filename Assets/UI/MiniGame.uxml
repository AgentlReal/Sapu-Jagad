<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:VisualElement name="MiniGameOverlay" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.7); justify-content: center; align-items: center;">
        <ui:VisualElement name="Panel" style="width: 600px; padding: 30px; background-color: white; border-radius: 10px;">
            <ui:Label name="Instruction" text="Susun kata-kata berikut!" style="font-size: 20px; color: black; -unity-text-align: middle-center; margin-bottom: 5px;" />
            <ui:Label name="Hint" text="Hint: ..." style="font-size: 16px; color: gray; -unity-text-align: middle-center; margin-bottom: 20px; -unity-font-style: italic; white-space: normal;" />
            <ui:Label name="CurrentSentence" text="..." style="font-size: 24px; color: green; -unity-text-align: middle-center; margin-bottom: 20px; white-space: normal;" />
            <ui:VisualElement name="WordContainer" style="flex-direction: row; flex-wrap: wrap; justify-content: center;" />
            <ui:Label name="MiniTimer" text="10" style="font-size: 30px; color: red; -unity-text-align: middle-center; margin-top: 20px;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>