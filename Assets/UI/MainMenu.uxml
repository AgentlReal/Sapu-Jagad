<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="MainMenuRoot" style="flex-grow: 1; background-image: url('project://database/Assets/Textures/UI/main_menu.png'); -unity-background-scale-mode: scale-and-crop; justify-content: center; align-items: center;">
        
        <ui:VisualElement name="MenuButtons" style="align-items: center; margin-top: 80px;">
            <ui:Button name="PlayButton" style="width: 300px; height: 120px; background-image: url('project://database/Assets/Textures/UI/play_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0; margin-bottom: 15px;" />
            <ui:Button name="HowToPlayButton" style="width: 300px; height: 117px; background-image: url('project://database/Assets/Textures/UI/how_to_play_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0; margin-bottom: 15px;" />
            <ui:Button name="SettingsButton" style="width: 300px; height: 117px; background-image: url('project://database/Assets/Textures/UI/settings_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0; margin-bottom: 15px;" />
            <ui:Button name="ExitButton" style="width: 300px; height: 117px; background-image: url('project://database/Assets/Textures/UI/exit_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0;" />
        </ui:VisualElement>

        <ui:VisualElement name="SettingsPanel" style="display: none; position: absolute; width: 100%; height: 100%; background-image: url('project://database/Assets/Textures/UI/settings_menu.png'); -unity-background-scale-mode: scale-and-crop; justify-content: center; align-items: center;">
            
            <ui:VisualElement name="SliderContainer" style="align-items: center; margin-top: 40px; width: 500px;">
                <ui:VisualElement name="VolumeRow" style="flex-direction: row; align-items: center; width: 100%; margin-bottom: 30px;">
                    <ui:Label text="Volume" style="font-size: 26px; color: white; width: 140px; -unity-font-style: bold;" />
                    <ui:Slider name="VolumeSlider" low-value="0" high-value="1" value="1" style="flex-grow: 1;" />
                </ui:VisualElement>

                <ui:VisualElement name="SFXRow" style="flex-direction: row; align-items: center; width: 100%; margin-bottom: 40px;">
                    <ui:Label text="SFX" style="font-size: 26px; color: white; width: 140px; -unity-font-style: bold;" />
                    <ui:Slider name="SFXSlider" low-value="0" high-value="1" value="1" style="flex-grow: 1;" />
                </ui:VisualElement>

                <ui:Button name="CloseSettingsButton" style="width: 240px; height: 94px; background-image: url('project://database/Assets/Textures/UI/back_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0;" />
            </ui:VisualElement>
        </ui:VisualElement>

        <ui:VisualElement name="HowToPlayPanel" style="display: none; position: absolute; width: 100%; height: 100%; background-image: url('project://database/Assets/Textures/UI/how_to_play_menu.png'); -unity-background-scale-mode: scale-and-crop; justify-content: flex-end; align-items: center; padding-bottom: 60px;">
            <ui:Button name="CloseHowToPlayButton" style="width: 240px; height: 94px; background-image: url('project://database/Assets/Textures/UI/back_button.png'); -unity-background-scale-mode: scale-to-fit; background-color: rgba(0,0,0,0); border-width: 0;" />
        </ui:VisualElement>

    </ui:VisualElement>
</ui:UXML>