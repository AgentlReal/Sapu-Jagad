<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="MainMenuRoot" style="flex-grow: 1; background-color: #1a1a2e; justify-content: center; align-items: center;">
        
        <ui:VisualElement name="TitleContainer" style="align-items: center; margin-bottom: 60px;">
            <ui:Label name="Title" text="Sapu Jagad" style="font-size: 72px; color: #e94560; -unity-font-style: bold; margin-bottom: 10px;" />
            <ui:Label name="Subtitle" text="Jaga Kebersihan, Jaga Hati Warga" style="font-size: 24px; color: #eaeaea; -unity-font-style: italic;" />
        </ui:VisualElement>

        <ui:VisualElement name="MenuButtons" style="align-items: center; width: 300px;">
            <ui:Button name="PlayButton" text="Main" style="width: 300px; height: 60px; font-size: 28px; background-color: #0f3460; color: white; border-radius: 12px; margin-bottom: 20px; border-width: 2px; border-color: #e94560;" />
            <ui:Button name="SettingsButton" text="Pengaturan" style="width: 300px; height: 60px; font-size: 28px; background-color: #0f3460; color: white; border-radius: 12px; margin-bottom: 20px; border-width: 2px; border-color: #16213e;" />
            <ui:Button name="ExitButton" text="Keluar" style="width: 300px; height: 60px; font-size: 28px; background-color: #0f3460; color: white; border-radius: 12px; border-width: 2px; border-color: #16213e;" />
        </ui:VisualElement>

        <ui:VisualElement name="SettingsPanel" style="display: none; position: absolute; width: 500px; padding: 40px; background-color: rgba(15, 52, 96, 0.95); border-radius: 15px; align-items: center; border-width: 2px; border-color: #e94560;">
            <ui:Label name="SettingsTitle" text="Pengaturan" style="font-size: 36px; color: white; -unity-font-style: bold; margin-bottom: 30px;" />
            
            <ui:VisualElement name="VolumeRow" style="flex-direction: row; align-items: center; width: 100%; margin-bottom: 20px;">
                <ui:Label text="Volume" style="font-size: 22px; color: white; width: 120px;" />
                <ui:Slider name="VolumeSlider" low-value="0" high-value="1" value="1" style="flex-grow: 1;" />
            </ui:VisualElement>

            <ui:VisualElement name="SFXRow" style="flex-direction: row; align-items: center; width: 100%; margin-bottom: 30px;">
                <ui:Label text="SFX" style="font-size: 22px; color: white; width: 120px;" />
                <ui:Slider name="SFXSlider" low-value="0" high-value="1" value="1" style="flex-grow: 1;" />
            </ui:VisualElement>

            <ui:Button name="CloseSettingsButton" text="Tutup" style="width: 200px; height: 50px; font-size: 22px; background-color: #e94560; color: white; border-radius: 10px;" />
        </ui:VisualElement>

    </ui:VisualElement>
</ui:UXML>
